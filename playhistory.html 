<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Play History - Shinzi Music</title>
    <style>
        body {
            margin: 0;
            background-color: #000000;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        
        /* Navigation Bar */
        .navbar {
            background-color: #121212;
            border-bottom: 1px solid #282828;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 15px;
            position: relative;
        }
        .back-btn {
            position: absolute;
            left: 20px;
            color: #1db954;
            text-decoration: none;
            font-size: 28px;
            font-weight: bold;
        }
        .navbar h1 {
            margin: 0;
            font-size: 22px;
            font-weight: 800;
            color: #ffffff;
        }

        /* Content */
        .header {
            font-size: 28px;
            font-weight: bold;
            padding: 20px;
            border-bottom: 1px solid #1e1e1e;
            margin-bottom: 10px;
            max-width: 600px;
            margin: 0 auto;
        }
        .container {
            padding: 10px 15px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* History Track List */
        .track-item {
            display: flex;
            align-items: center;
            background-color: #121212;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 12px;
            transition: background-color 0.2s;
        }
        .track-item:active {
            background-color: #1e1e1e;
        }
        
        /* Album Art Placeholder */
        .track-img {
            width: 55px;
            height: 55px;
            border-radius: 8px;
            background: linear-gradient(135deg, #2a2a2a, #121212);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-right: 15px;
            flex-shrink: 0;
            object-fit: cover;
        }
        
        .track-info {
            flex-grow: 1;
            overflow: hidden;
        }
        .track-title {
            margin: 0 0 4px 0;
            font-size: 16px;
            font-weight: 700;
            color: #ffffff;
            white-space: nowrap;
            text-overflow: ellipsis;
            overflow: hidden;
        }
        .track-artist {
            margin: 0;
            font-size: 13px;
            color: #a7a7a7;
        }
        
        /* Play Button */
        .play-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #1db954;
            color: #000;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            padding-left: 4px; /* visually centers the play triangle */
            cursor: pointer;
            flex-shrink: 0;
            margin-left: 10px;
            transition: transform 0.1s;
        }
        .play-btn:active {
            transform: scale(0.92);
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="settings.html" class="back-btn">‹</a>
        <h1>History</h1>
    </nav>

    <div class="header">Recently Played</div>

    <div class="container" id="historyContainer">
        
        <!-- Mock Track 1 -->
        <div class="track-item">
            <div class="track-img">🎵</div>
            <div class="track-info">
                <p class="track-title">Loading Track...</p>
                <p class="track-artist">Unknown Artist</p>
            </div>
            <button class="play-btn" onclick="playSong('Loading Track...')">▶</button>
        </div>

        <!-- Mock Track 2 -->
        <div class="track-item">
            <div class="track-img">🎵</div>
            <div class="track-info">
                <p class="track-title">Previous Song</p>
                <p class="track-artist">Shinzi Audio</p>
            </div>
            <button class="play-btn" onclick="playSong('Previous Song')">▶</button>
        </div>

        <!-- Mock Track 3 -->
        <div class="track-item">
            <div class="track-img">🎵</div>
            <div class="track-info">
                <p class="track-title">Test Audio Stream</p>
                <p class="track-artist">System</p>
            </div>
            <button class="play-btn" onclick="playSong('Test Audio Stream')">▶</button>
        </div>

    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
        import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-auth.js";

        // Stealth Key
        const firebaseConfig = {
            apiKey: ['AIzaSyA9', '-BquJOixe2dku', 'MA4OR_LH_', '-4kqcFrRE'].join(''),
            authDomain: "shinzi-music.firebaseapp.com",
            projectId: "shinzi-music"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        // Security Check
        onAuthStateChanged(auth, (user) => {
            if (!user) {
                window.location.href = "login.html";
            }
        });

        // Dummy Play Function (Will connect to your real player later)
        window.playSong = (songName) => {
            alert("Now Playing: " + songName + "\n(This will link to the Shinzi Music player engine later!)");
        };
    </script>
</body>
</html>
