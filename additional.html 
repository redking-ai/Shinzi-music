<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Additional Settings</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, sans-serif; }
        body { background-color: #000; color: #fff; padding: 20px; }
        .header { display: flex; align-items: center; margin-bottom: 30px; font-size: 20px; font-weight: 700; border-bottom: 1px solid #282828; padding-bottom: 10px; }
        .back-btn { text-decoration: none; color: #fff; margin-right: 16px; font-size: 24px; }
        .row { display: flex; justify-content: space-between; align-items: center; padding: 16px; background: #121212; border-radius: 8px; border: 1px solid #282828; }
        
        /* CSS Toggle Switch */
        .toggle { width: 40px; height: 20px; background: #282828; border-radius: 10px; position: relative; cursor: pointer; }
        .knob { width: 16px; height: 16px; background: #fff; border-radius: 50%; position: absolute; top: 2px; left: 2px; transition: 0.2s; }
        .input-check { display: none; }
        .input-check:checked + .toggle { background: #1db954; }
        .input-check:checked + .toggle .knob { transform: translateX(20px); }
    </style>
</head>
<body>
    <div class="header"><a href="settings.html" class="back-btn">←</a> Additional Settings</div>
    
    <label class="row">
        <span>Developer Option</span>
        <input type="checkbox" class="input-check">
        <div class="toggle"><div class="knob"></div></div>
    </label>
</body>
</html>
